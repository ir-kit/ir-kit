{
  "name": "contract-kit",
  "private": true,
  "description": "Toolkit for OpenAPI / AsyncAPI / SDK contract codegen",
  "homepage": "https://github.com/ahmedrowaihi/contract-kit",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/contract-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/contract-kit.git"
  },
  "type": "module",
  "scripts": {
    "prepare": "lefthook install",
    "build": "turbo run build --filter=!./examples/*",
    "build:examples": "turbo run build --filter=./examples/*",
    "dev": "turbo run dev --filter=!./examples/*",
    "typecheck": "turbo run typecheck --filter=!./examples/*",
    "test": "turbo run test --filter=!./examples/*",
    "format": "biome check --write .",
    "format:check": "biome ci .",
    "deps:check": "manypkg check",
    "deps:fix": "manypkg fix",
    "sync:readme": "node scripts/sync-readme.mjs",
    "new-package": "node scripts/new-package.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version && pnpm install --lockfile-only",
    "release": "turbo run build --filter=!./examples/* && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.13",
    "@changesets/cli": "^2.31.0",
    "@manypkg/cli": "^0.25.1",
    "lefthook": "^2.1.6",
    "turbo": "^2.9.6",
    "typescript": "catalog:"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20.19.0"
  }
}
