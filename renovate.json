{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    ":semanticCommits",
    ":prHourlyLimitNone",
    "group:allNonMajor",
    "schedule:earlyMondays",
    "helpers:pinGitHubActionDigests",
    ":label(dependencies)"
  ],
  "timezone": "UTC",
  "schedule": ["* 0-11 * * 1-5"],
  "prConcurrentLimit": 4,
  "prHourlyLimit": 2,
  "rebaseWhen": "conflicted",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 0-11 * * 1"],
    "automerge": true
  },
  "packageRules": [
    {
      "description": "Group all @types/* together",
      "matchPackageNames": ["@types/**"],
      "groupName": "type definitions",
      "automerge": true
    },
    {
      "description": "Group JS/TS tooling",
      "matchPackageNames": [
        "typescript",
        "eslint",
        "prettier",
        "vitest",
        "@vitest/**",
        "tsx",
        "tsup",
        "turbo",
        "jiti",
        "@typescript-eslint/**",
        "eslint-**"
      ],
      "groupName": "js tooling",
      "automerge": true
    },
    {
      "description": "Group + pin GitHub Actions",
      "matchManagers": ["github-actions"],
      "groupName": "github-actions",
      "pinDigests": true,
      "automerge": true,
      "minimumReleaseAge": "3 days"
    },
    {
      "description": "Auto-merge devDependencies on green CI",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true,
      "automergeType": "pr",
      "platformAutomerge": true
    },
    {
      "description": "Auto-merge pnpm catalog patch/minor (treated as shared dev tooling)",
      "matchDepTypes": ["pnpm.catalog.default"],
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "Hold prod / peer deps majors for soak time, never automerge",
      "matchDepTypes": ["dependencies", "peerDependencies"],
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "minimumReleaseAge": "14 days"
    },
    {
      "description": "Ignore internal workspace packages — they're released via changesets",
      "matchPackageNames": ["@ahmedrowaihi/**"],
      "matchCurrentValue": "/^workspace:/",
      "enabled": false
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/.changeset/**"]
}
