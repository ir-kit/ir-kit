{
  "name": "@ahmedrowaihi/k6-tools",
  "version": "0.2.0",
  "description": "CLI for the @ahmedrowaihi/k6 framework. Scaffold load tests (init), regenerate the typed client (sync), bundle+run scripts against the real k6 binary, replay recorded traffic.",
  "keywords": [
    "k6",
    "load-testing",
    "cli",
    "openapi"
  ],
  "homepage": "https://github.com/ahmedrowaihi/contract-kit/tree/main/packages/k6/tools",
  "bugs": {
    "url": "https://github.com/ahmedrowaihi/contract-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ahmedrowaihi/contract-kit.git",
    "directory": "packages/k6/tools"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "k6-tools": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && chmod +x dist/bin.js",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ahmedrowaihi/k6-gen": "workspace:*",
    "@ahmedrowaihi/openapi-tools": "workspace:*",
    "c12": "catalog:",
    "citty": "catalog:",
    "consola": "catalog:",
    "esbuild": "catalog:",
    "tinyglobby": "catalog:"
  },
  "devDependencies": {
    "@ahmedrowaihi/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
