{
  "name": "@ir-kit/openapi-ts-k6",
  "version": "0.1.2",
  "description": "Thin @hey-api/openapi-ts plugin that delegates to @ir-kit/k6-gen. Use if you already drive codegen through openapi-ts.config.ts; otherwise reach for @ir-kit/k6-toolkit.",
  "keywords": [
    "openapi",
    "openapi-ts",
    "k6",
    "load-testing",
    "plugin"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/k6/hey-api",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/k6/hey-api"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ir-kit/k6-gen": "workspace:*"
  },
  "peerDependencies": {
    "@hey-api/openapi-ts": ">=0.95.0",
    "@hey-api/shared": ">=0.2.0"
  },
  "devDependencies": {
    "@hey-api/openapi-ts": "catalog:",
    "@hey-api/shared": "catalog:",
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
