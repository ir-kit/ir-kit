{
  "name": "@ir-kit/fn-schema-cli",
  "version": "0.1.0",
  "description": "CLI wrapper for fn-schema. Thin orchestrator over @ir-kit/fn-schema-core with the TypeScript extractor pre-registered. Loads optional fn-schema.config.{ts,js,json} via c12.",
  "keywords": [
    "json-schema",
    "function-signature",
    "cli",
    "codegen"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/fn-schema/cli",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/fn-schema/cli"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "fn-schema": "./dist/bin.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@ir-kit/fn-schema-core": "workspace:*",
    "@ir-kit/fn-schema-typescript": "workspace:*",
    "c12": "catalog:",
    "chokidar": "catalog:",
    "citty": "catalog:",
    "consola": "catalog:",
    "tinyglobby": "catalog:"
  },
  "devDependencies": {
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
