{
  "name": "@ir-kit/schema",
  "version": "0.2.0",
  "description": "Canonical JSON Schema 2020-12 IR shared across OpenAPI and AsyncAPI codegen families. Source-agnostic schema model + adapters from hey-api's IR.SchemaObject and @asyncapi/parser schemas.",
  "keywords": [
    "json-schema",
    "json-schema-2020-12",
    "ir",
    "codegen",
    "openapi",
    "asyncapi"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/shared/schema",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/shared/schema"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./adapters/heyapi": {
      "types": "./dist/adapters/heyapi.d.ts",
      "import": "./dist/adapters/heyapi.js"
    },
    "./adapters/jsonschema": {
      "types": "./dist/adapters/jsonschema.d.ts",
      "import": "./dist/adapters/jsonschema.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@hey-api/shared": ">=0.3.0"
  },
  "peerDependenciesMeta": {
    "@hey-api/shared": {
      "optional": true
    }
  },
  "dependencies": {
    "@ir-kit/codegen-core": "workspace:*",
    "json-schema-typed": "catalog:"
  },
  "devDependencies": {
    "@hey-api/shared": "catalog:",
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
