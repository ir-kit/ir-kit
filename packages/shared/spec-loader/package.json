{
  "name": "@ir-kit/spec-loader",
  "version": "0.2.0",
  "description": "Universal spec loader for OpenAPI, AsyncAPI, and TypeSpec. Detects format by extension + content sniff and dispatches to the per-format loader, returning a discriminated `{ kind, document }` result.",
  "keywords": [
    "openapi",
    "asyncapi",
    "typespec",
    "loader",
    "spec",
    "ir-kit"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/shared/spec-loader",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/shared/spec-loader"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@asyncapi/parser": "catalog:"
  },
  "dependencies": {
    "@ir-kit/asyncapi-loader": "workspace:*",
    "@ir-kit/openapi-loader": "workspace:*",
    "@ir-kit/typespec-loader": "workspace:*"
  },
  "devDependencies": {
    "@asyncapi/parser": "catalog:",
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
