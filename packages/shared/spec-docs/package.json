{
  "name": "@ir-kit/spec-docs",
  "version": "0.1.0",
  "description": "Render any API spec as standalone HTML documentation via Scalar API Reference. Programmatic + CLI.",
  "keywords": [
    "openapi",
    "asyncapi",
    "typespec",
    "protobuf",
    "postman",
    "docs",
    "scalar",
    "ir-kit"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/shared/spec-docs",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/shared/spec-docs"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@ir-kit/spec-convert": "workspace:*",
    "@scalar/core": "^0.5.9"
  },
  "devDependencies": {
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
