{
  "name": "@ir-kit/cli",
  "version": "0.1.0",
  "description": "Unified `ir` CLI — single entry point for spec loading, conversion, codegen, and reverse-engineering across every supported API standard. Commands are JSON-Schema-defined; runtime auto-derives flags, prompts, help, and validation from the schema.",
  "keywords": [
    "cli",
    "openapi",
    "asyncapi",
    "typespec",
    "codegen",
    "ir-kit"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/cli",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/cli"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "bin": {
    "ir": "./dist/bin.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@clack/prompts": "catalog:",
    "@ir-kit/fn-schema-core": "workspace:*",
    "@ir-kit/fn-schema-typescript": "workspace:*",
    "@ir-kit/k6-gen": "workspace:*",
    "@ir-kit/k6-toolkit": "workspace:*",
    "@ir-kit/openapi-go": "workspace:*",
    "@ir-kit/openapi-kotlin": "workspace:*",
    "@ir-kit/openapi-recon": "workspace:*",
    "@ir-kit/openapi-swift": "workspace:*",
    "@ir-kit/openapi-typescript": "workspace:*",
    "@ir-kit/schema": "workspace:*",
    "@ir-kit/spec-convert": "workspace:*",
    "@ir-kit/spec-loader": "workspace:*",
    "chokidar": "catalog:",
    "citty": "catalog:",
    "consola": "catalog:"
  },
  "devDependencies": {
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
