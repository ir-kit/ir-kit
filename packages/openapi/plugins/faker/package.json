{
  "name": "@ir-kit/openapi-ts-faker",
  "version": "0.1.0",
  "description": "Faker.js plugin for @hey-api/openapi-ts - Generate realistic mock data factories from OpenAPI specs",
  "keywords": [
    "openapi",
    "openapi-ts",
    "faker",
    "fakerjs",
    "mock",
    "mocking",
    "testing",
    "typescript",
    "codegen",
    "type-safe",
    "plugin"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/openapi/plugins/faker",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/openapi/plugins/faker"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@faker-js/faker": "^10.0.0 || ^9.0.0 || ^8.0.0",
    "@hey-api/codegen-core": ">=0.7.0",
    "@hey-api/openapi-ts": ">=0.95.0",
    "@hey-api/shared": ">=0.2.0",
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@hey-api/codegen-core": "catalog:",
    "@hey-api/openapi-ts": "catalog:",
    "@hey-api/shared": "catalog:",
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
