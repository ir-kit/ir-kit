{
  "name": "@ir-kit/openapi-swift",
  "version": "1.0.0",
  "description": "Generate idiomatic Swift (Codable + URLSession + async throws) client SDKs from an OpenAPI 3.x spec.",
  "keywords": [
    "openapi",
    "swift",
    "ios",
    "urlsession",
    "codable",
    "codegen",
    "sdk",
    "client"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/openapi/swift",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/openapi/swift"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "peerDependencies": {
    "@hey-api/shared": ">=0.3.0",
    "@hey-api/spec-types": ">=0.2.0",
    "@ir-kit/openapi-tools": ">=0.2.0"
  },
  "dependencies": {
    "@ir-kit/codegen-core": "workspace:*",
    "@ir-kit/openapi": "workspace:*",
    "@ir-kit/openapi-loader": "workspace:*"
  },
  "devDependencies": {
    "@hey-api/shared": "catalog:",
    "@hey-api/spec-types": "catalog:",
    "@ir-kit/openapi-tools": "workspace:*",
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
