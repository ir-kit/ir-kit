{
  "name": "@ir-kit/openapi-loader",
  "version": "0.2.0",
  "description": "Load an OpenAPI 3.x spec from a file path, URL, or pre-parsed object. Bundles `$ref`s via `@hey-api/json-schema-ref-parser` and runs optional hey-api-aware normalization.",
  "keywords": [
    "openapi",
    "loader",
    "ref-parser",
    "spec",
    "ir-kit"
  ],
  "homepage": "https://github.com/ir-kit/ir-kit/tree/main/packages/openapi/loader",
  "bugs": {
    "url": "https://github.com/ir-kit/ir-kit/issues"
  },
  "license": "MIT",
  "author": {
    "name": "Ahmed Rowaihi",
    "email": "ahmedrowaihi@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ir-kit/ir-kit.git",
    "directory": "packages/openapi/loader"
  },
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE.md"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@hey-api/json-schema-ref-parser": "catalog:",
    "@ir-kit/openapi": "workspace:*"
  },
  "devDependencies": {
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "vitest": "catalog:"
  },
  "engines": {
    "node": ">=20.19.0"
  }
}
