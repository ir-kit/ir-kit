{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "files": {
    "includes": [
      "**",
      "!!**/dist/**",
      "!!**/node_modules/**",
      "!!**/.next/**",
      "!!**/.turbo/**",
      "!!**/.wxt/**",
      "!!**/.output/**",
      "!!**/globals.css",
      "!!**/.vscode/**",
      "!!**/cdk.out/**",
      "!!**/.build/**",
      "!!**/.swiftpm/**",
      "!!**/.gradle/**",
      "!!**/build/**",
      "!!**/Package.resolved",
      "!!examples/**/sdk/**",
      "!!examples/**/generated/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "formatWithErrors": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 80
  },
  "linter": {
    "enabled": false
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double"
    }
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  }
}
