{
  "name": "@ir-kit/example-fn-schema-basic",
  "version": "0.0.2",
  "private": true,
  "type": "module",
  "description": "Demonstrates @ir-kit/fn-schema-typescript: extract input/output JSON Schemas from real TypeScript function signatures and verify them with vitest.",
  "scripts": {
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "generate": "node scripts/generate.mjs",
    "extract": "ir fn-schema extract --patterns \"src/**/*.ts\" --out generated/cli --pretty --naming file-function"
  },
  "dependencies": {
    "@ir-kit/fn-schema-core": "workspace:*",
    "@ir-kit/fn-schema-loader": "workspace:*",
    "@ir-kit/fn-schema-typescript": "workspace:*"
  },
  "devDependencies": {
    "@ir-kit/cli": "workspace:*",
    "@ir-kit/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "typescript": "5.9.3",
    "vitest": "catalog:"
  }
}
